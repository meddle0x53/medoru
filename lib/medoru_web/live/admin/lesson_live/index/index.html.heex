<Layouts.app flash={@flash} current_scope={@current_scope} socket={@socket}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <%!-- Header --%>
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <div class="flex items-center gap-2 mb-2">
          <.link navigate={~p"/admin"} class="btn btn-sm btn-ghost">
            <.icon name="hero-arrow-left" class="w-4 h-4" />
          </.link>
          <h1 class="text-3xl font-bold text-base-content">{gettext("Lesson Management")}</h1>
        </div>
        <p class="mt-1 text-secondary">
          {gettext("Manage lessons. Total: %{count}", count: @total_count)}
        </p>
      </div>
      <.link
        navigate={~p"/admin/lessons/new"}
        class="btn btn-primary w-full sm:w-auto min-h-[44px] touch-target"
      >
        <.icon name="hero-plus" class="w-5 h-5 mr-2" /> {gettext("Add Lesson")}
      </.link>
    </div>

    <%!-- Filters --%>
    <div class="card bg-base-100 shadow-sm border border-base-300 mb-6">
      <div class="card-body p-4 sm:p-6">
        <div class="flex flex-col gap-4">
          <%!-- Difficulty Filter --%>
          <div class="flex flex-col sm:flex-row sm:items-center gap-2">
            <span class="text-sm font-medium text-base-content/70 shrink-0">
              {gettext("Filter by level:")}
            </span>
            <div class="flex flex-wrap gap-1">
              <button
                phx-click="filter_difficulty"
                phx-value-difficulty=""
                class={[
                  "btn btn-sm min-h-[40px] touch-target",
                  if(is_nil(@difficulty_filter), do: "btn-active btn-primary", else: "btn-ghost")
                ]}
              >
                {gettext("All")}
              </button>
              <%= for diff <- 5..1//-1 do %>
                <button
                  phx-click="filter_difficulty"
                  phx-value-difficulty={diff}
                  class={[
                    "btn btn-sm min-h-[40px] touch-target",
                    if(@difficulty_filter == to_string(diff),
                      do: "btn-active btn-primary",
                      else: "btn-ghost"
                    )
                  ]}
                >
                  N{diff}
                </button>
              <% end %>
            </div>
          </div>

          <%!-- Search --%>
          <.form
            for={%{}}
            phx-submit="search"
            class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2 w-full"
          >
            <div class="join w-full sm:flex-1">
              <input
                type="text"
                name="search[query]"
                value={@search}
                placeholder={gettext("Search lesson title...")}
                class="join-item input input-bordered w-full text-base min-h-[48px]"
              />
            </div>
            <div class="flex gap-2">
              <button
                type="submit"
                class="btn btn-primary min-h-[48px] touch-target flex-1 sm:flex-none px-4"
              >
                <.icon name="hero-magnifying-glass" class="w-5 h-5 sm:mr-2" />
                <span class="hidden sm:inline">{gettext("Search")}</span>
              </button>
              <%= if @search || @difficulty_filter do %>
                <button
                  type="button"
                  phx-click="clear_filters"
                  class="btn btn-ghost min-h-[48px] touch-target px-4"
                >
                  {gettext("Clear")}
                </button>
              <% end %>
            </div>
          </.form>
        </div>
      </div>
    </div>

    <%!-- Lessons Grid --%>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <%= for lesson <- @lessons do %>
        <div class="card bg-base-100 shadow-sm border border-base-300 hover:shadow-md transition-shadow">
          <div class="card-body p-4">
            <div class="flex justify-between items-start mb-2">
              <div class="flex items-center gap-2">
                <span class={["badge badge-sm", difficulty_badge_color(lesson.difficulty)]}>
                  N{lesson.difficulty}
                </span>
                <.icon
                  name={lesson_type_icon(lesson.lesson_type)}
                  class="w-4 h-4 text-base-content/50"
                />
              </div>
              <div class="flex gap-1">
                <.link
                  navigate={~p"/admin/lessons/#{lesson.id}/edit"}
                  class="btn btn-ghost btn-sm min-h-[36px] min-w-[36px] touch-target"
                  title={gettext("Edit")}
                >
                  <.icon name="hero-pencil" class="w-4 h-4" />
                </.link>
                <button
                  phx-click="delete"
                  phx-value-id={lesson.id}
                  data-confirm={gettext("Are you sure you want to delete this lesson?")}
                  class="btn btn-ghost btn-sm text-error min-h-[36px] min-w-[36px] touch-target"
                  title={gettext("Delete")}
                >
                  <.icon name="hero-trash" class="w-4 h-4" />
                </button>
              </div>
            </div>

            <h3 class="font-semibold text-base-content truncate" title={lesson.title}>
              {lesson.title}
            </h3>

            <p class="text-sm text-base-content/60 mt-1 line-clamp-2">
              {lesson.description}
            </p>

            <div class="flex items-center justify-between mt-3 pt-3 border-t border-base-300">
              <div class="flex items-center gap-2 text-sm text-base-content/60">
                <.icon name="hero-book-open" class="w-4 h-4" />
                <span>
                  {length(lesson.lesson_words || [])} {gettext("words")}
                </span>
              </div>

              <%= if lesson.translations != %{} do %>
                <div class="flex gap-1">
                  <%= if get_in(lesson.translations, ["bg", "title"]) do %>
                    <span class="badge badge-xs badge-primary">BG</span>
                  <% end %>
                  <%= if get_in(lesson.translations, ["ja", "title"]) do %>
                    <span class="badge badge-xs badge-secondary">JA</span>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%= if @lessons == [] do %>
      <div class="p-12 text-center">
        <.icon name="hero-academic-cap" class="w-12 h-12 text-base-content/30 mx-auto mb-4" />
        <p class="text-base-content/50">{gettext("No lessons found matching your criteria.")}</p>
      </div>
    <% end %>

    <%!-- Pagination --%>
    <%= if @total_pages > 1 do %>
      <div class="flex items-center justify-between mt-6">
        <div class="text-sm text-base-content/60">
          {gettext("Page %{page} of %{total}", page: @page, total: @total_pages)}
        </div>
        <div class="join">
          <.link
            navigate={
              if @page > 1,
                do:
                  ~p"/admin/lessons?#{%{page: @page - 1, difficulty: @difficulty_filter, search: @search}}",
                else: "#"
            }
            class={["join-item btn btn-sm min-w-[40px]", if(@page <= 1, do: "btn-disabled")]}
          >
            <.icon name="hero-chevron-left" class="w-4 h-4" />
          </.link>
          <%= for page_num <- 1..@total_pages do %>
            <%= if abs(page_num - @page) <= 2 or page_num == 1 or page_num == @total_pages do %>
              <.link
                navigate={
                  ~p"/admin/lessons?#{%{page: page_num, difficulty: @difficulty_filter, search: @search}}"
                }
                class={[
                  "join-item btn btn-sm w-10 h-10 min-w-[40px] max-w-[40px] p-0",
                  if(page_num == @page, do: "btn-active btn-primary", else: "btn-ghost")
                ]}
              >
                {page_num}
              </.link>
            <% end %>
          <% end %>
          <.link
            navigate={
              if @page < @total_pages,
                do:
                  ~p"/admin/lessons?#{%{page: @page + 1, difficulty: @difficulty_filter, search: @search}}",
                else: "#"
            }
            class={[
              "join-item btn btn-sm min-w-[40px]",
              if(@page >= @total_pages, do: "btn-disabled")
            ]}
          >
            <.icon name="hero-chevron-right" class="w-4 h-4" />
          </.link>
        </div>
      </div>
    <% end %>
  </div>
</Layouts.app>
