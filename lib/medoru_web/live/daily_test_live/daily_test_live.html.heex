<Layouts.app flash={@flash} current_scope={@current_scope} socket={@socket}>
  <div class="max-w-3xl mx-auto px-3 sm:px-4 py-4 sm:py-8">
    <%= if @already_completed do %>
      <div class="bg-base-100 rounded-2xl shadow-sm border border-base-200 p-6 sm:p-8 text-center">
        <div class="w-16 h-16 sm:w-24 sm:h-24 bg-success/20 rounded-full flex items-center justify-center mx-auto mb-4 sm:mb-6">
          <.icon name="hero-check-circle" class="w-8 h-8 sm:w-12 sm:h-12 text-success" />
        </div>
        <h1 class="text-xl sm:text-2xl font-bold text-base-content mb-2">
          {gettext("Daily Review Complete!")} 🎉
        </h1>
        <p class="text-secondary mb-4 sm:mb-6 text-sm sm:text-base">
          {gettext(
            "You've already completed your daily review today. Great job keeping up with your studies!"
          )}
        </p>
        <div class="flex gap-3 sm:gap-4 justify-center">
          <.link
            navigate={~p"/dashboard"}
            class="inline-flex items-center justify-center gap-2 px-4 sm:px-6 py-2.5 sm:py-3 bg-primary text-primary-content rounded-xl font-medium hover:bg-primary/90 transition-colors min-h-[44px]"
          >
            <.icon name="hero-home" class="w-5 h-5" /> {gettext("Back to Dashboard")}
          </.link>
        </div>
      </div>
    <% else %>
      <%!-- Header --%>
      <div class="mb-4 sm:mb-8">
        <div class="flex items-center gap-2 text-xs sm:text-sm text-secondary mb-1 sm:mb-2">
          <.link
            navigate={~p"/dashboard"}
            class="hover:text-primary transition-colors flex items-center gap-1"
          >
            <.icon name="hero-arrow-left" class="w-4 h-4" /> {gettext("Back to Dashboard")}
          </.link>
        </div>
        <h1 class="text-xl sm:text-2xl font-bold text-base-content">{gettext("Daily Review")}</h1>
        <p class="text-secondary mt-1 text-sm sm:text-base">
          {gettext("Keep your streak going with today's review")}
        </p>
      </div>

      <%= if @current_step do %>
        <%!-- Progress Bar --%>
        <div class="mb-4 sm:mb-8">
          <div class="flex justify-between text-xs sm:text-sm mb-1 sm:mb-2">
            <span class="text-secondary">
              {gettext("Question %{current} of %{total}",
                current: @session_state.completed_steps + 1,
                total: @session_state.total_steps
              )}
            </span>
            <span class="text-secondary">{@session_state.progress}{gettext(" complete")}</span>
          </div>
          <div class="h-1.5 sm:h-2 bg-base-200 rounded-full overflow-hidden">
            <div
              class="h-full bg-primary transition-all duration-300"
              style={"width: #{@session_state.progress}%"}
            >
            </div>
          </div>
        </div>

        <%!-- Question Card --%>
        <div class="bg-base-100 rounded-2xl shadow-sm border border-base-200 p-4 sm:p-6 mb-4 sm:mb-6">
          <%= cond do %>
            <% @current_step.question_type == :writing -> %>
              <%!-- Writing Question (Kanji Drawing) --%>
              <div class="mb-4 sm:mb-6">
                <div class="flex items-center gap-2 text-primary mb-3">
                  <.icon name="hero-pencil" class="w-5 h-5" />
                  <span class="text-sm font-medium">{gettext("Writing Challenge (3 points)")}</span>
                </div>
                <h2 class="text-xl font-semibold text-base-content leading-relaxed">
                  {translate_question(@current_step.question)}
                </h2>
              </div>

              <%!-- Hint --%>
              <%= if @show_hint && List.first(@current_step.hints) do %>
                <div class="bg-info/10 text-info rounded-lg p-3 mb-4">
                  <div class="flex items-center gap-2">
                    <.icon name="hero-light-bulb" class="w-5 h-5" />
                    <span>{List.first(@current_step.hints)}</span>
                  </div>
                </div>
              <% end %>

              <%!-- Writing Canvas Component --%>
              <MedoruWeb.LessonTestLive.WritingComponent.writing_question
                step={@current_step}
                target="writing-component"
              />

              <%!-- Actions for Writing --%>
              <div class="flex flex-col sm:flex-row gap-3 mt-4 sm:mt-6">
                <%= if @feedback != :incorrect do %>
                  <%= if !@show_hint do %>
                    <button
                      type="button"
                      phx-click="show_hint"
                      class="w-full sm:w-auto px-4 py-3 bg-info/10 hover:bg-info/20 text-info rounded-xl transition-colors min-h-[48px]"
                    >
                      <div class="flex items-center justify-center gap-2">
                        <.icon name="hero-light-bulb" class="w-5 h-5" />
                        <span>{gettext("Hint")}</span>
                      </div>
                    </button>
                  <% end %>

                  <button
                    type="button"
                    phx-click="skip_question"
                    class="w-full sm:w-auto sm:ml-auto px-4 py-3 bg-base-200 hover:bg-base-300 text-base-content rounded-xl transition-colors min-h-[48px]"
                  >
                    {gettext("Skip →")}
                  </button>
                <% else %>
                  <button
                    type="button"
                    phx-click="continue_after_correction"
                    class="px-4 sm:px-6 py-2.5 sm:py-3 bg-primary text-primary-content rounded-xl font-medium hover:bg-primary/90 transition-colors min-h-[44px]"
                  >
                    {gettext("Continue →")}
                  </button>
                <% end %>
              </div>

            <% @current_step.question_type == :reading_text -> %>
              <%!-- Reading Text Question --%>
              <% translated_step = %{
                @current_step
                | question: translate_question(@current_step.question),
                  hints: Enum.map(@current_step.hints, &translate_hint/1)
              } %>
              <MedoruWeb.LessonTestLive.ReadingTextComponent.reading_text_question
                step={translated_step}
                meaning_answer={@meaning_answer}
                reading_answer={@reading_answer}
                feedback={@feedback}
                show_hint={@show_hint}
                meaning_error={@meaning_error}
                reading_error={@reading_error}
                correct_meaning={@correct_meaning}
                correct_reading={@correct_reading}
              />

              <%!-- Actions for Reading Text --%>
              <div class="flex flex-col sm:flex-row gap-3 mt-4 sm:mt-6">
                <%= if @feedback != :incorrect do %>
                  <button
                    type="button"
                    phx-click="submit_reading_text"
                    disabled={@meaning_answer == "" or @reading_answer == ""}
                    class="w-full sm:w-auto px-4 sm:px-6 py-3 bg-primary text-primary-content rounded-xl font-medium hover:bg-primary/90 disabled:opacity-50 disabled:cursor-not-allowed transition-colors min-h-[48px] order-1"
                  >
                    {gettext("Submit Answer")}
                  </button>

                  <button
                    type="button"
                    phx-click="skip_question"
                    class="w-full sm:w-auto sm:ml-auto px-4 py-3 bg-base-200 hover:bg-base-300 text-base-content rounded-xl transition-colors min-h-[48px] order-2 sm:order-3"
                  >
                    {gettext("Skip →")}
                  </button>
                <% else %>
                  <button
                    type="button"
                    phx-click="continue_after_correction"
                    class="px-4 sm:px-6 py-2.5 sm:py-3 bg-primary text-primary-content rounded-xl font-medium hover:bg-primary/90 transition-colors min-h-[44px]"
                  >
                    {gettext("Continue →")}
                  </button>
                <% end %>
              </div>

            <% true -> %>
            <%!-- Multichoice Question --%>
            <%!-- Question --%>
            <div class="mb-4 sm:mb-6">
              <div class="text-xs sm:text-sm text-secondary mb-3 sm:mb-4">
                {translate_question(@current_step.question)}
              </div>
              <h2 class="text-3xl sm:text-4xl font-bold text-primary font-japanese text-center mb-3 sm:mb-4">
                {@current_step.question_data["word_text"]}
              </h2>
              <%!-- Show hint based on question type --%>
              <%= if @current_step.question_data["type"] == "word_to_meaning" do %>
                <p class="text-center text-secondary text-sm sm:text-base">
                  {gettext("Reading:")} {@current_step.question_data["word_reading"]}
                </p>
              <% else %>
                <p class="text-center text-secondary text-sm sm:text-base">
                  {gettext("Meaning:")} {localize_question_data_meaning(
                    @current_step.question_data,
                    @locale
                  )}
                </p>
              <% end %>
            </div>

            <%!-- Hint --%>
            <%= if @show_hint && List.first(@current_step.hints) do %>
              <div class="bg-info/10 text-info rounded-lg p-3 mb-4">
                <div class="flex items-center gap-2 text-sm">
                  <.icon name="hero-light-bulb" class="w-5 h-5 shrink-0" />
                  <span>{translate_hint(List.first(@current_step.hints))}</span>
                </div>
              </div>
            <% end %>

            <%!-- Answer Options --%>
            <div class={[
              "mb-4 sm:mb-6",
              if @current_step.question_data["type"] == "image_to_meaning" do
                "grid grid-cols-2 gap-3 sm:gap-4"
              else
                "space-y-2 sm:space-y-3"
              end
            ]}>
              <%= for {option, index} <- Enum.with_index(@current_step.options) do %>
                <% display_option =
                  cond do
                    @current_step.question_data["type"] == "word_to_meaning" ->
                      localize_option(option, @locale)
                    @current_step.question_data["type"] == "image_to_meaning" ->
                      option
                    true ->
                      option
                  end %>
                <% image_data =
                  if @current_step.question_data["type"] == "image_to_meaning" do
                    @current_step.question_data["image_options"] |> Enum.at(index)
                  else
                    nil
                  end %>
                <% is_image_type = @current_step.question_data["type"] == "image_to_meaning" %>
                <% is_selected = @selected_answer == option %>
                <button
                  type="button"
                  phx-click="select_answer"
                  phx-value-answer={option}
                  class={[
                    "transition-all duration-200 min-h-[48px]",
                    if is_image_type do
                      "relative rounded-xl border-2 overflow-hidden aspect-square"
                    else
                      "w-full text-left p-3 sm:p-4 rounded-xl border-2"
                    end,
                    if is_image_type and is_selected do
                      "border-primary ring-2 ring-primary"
                    end,
                    if is_image_type and not is_selected do
                      "border-base-200 hover:border-primary/50 hover:shadow-md"
                    end,
                    if not is_image_type and is_selected do
                      "border-primary bg-primary/5"
                    end,
                    if not is_image_type and not is_selected do
                      "border-base-200 hover:border-primary/50 hover:bg-base-50"
                    end
                  ]}
                >
                  <%= if @current_step.question_data["type"] == "image_to_meaning" do %>
                    <%!-- Image Option --%>
                    <%= if image_data && image_data["image_path"] do %>
                      <img
                        src={image_data["image_path"]}
                        alt={display_option}
                        class="w-full h-full object-cover"
                        loading="lazy"
                      />
                    <% else %>
                      <div class="w-full h-full flex items-center justify-center bg-base-200">
                        <span class="text-secondary text-sm text-center px-2">
                          {display_option}
                        </span>
                      </div>
                    <% end %>
                    
                    <%!-- Selection Indicator (top-right corner) --%>
                    <div class={[
                      "absolute top-2 right-2 w-6 h-6 rounded-full border-2 flex items-center justify-center bg-white/90 backdrop-blur",
                      if @selected_answer == option do
                        "border-primary bg-primary"
                      else
                        "border-base-300"
                      end
                    ]}>
                      <%= if @selected_answer == option do %>
                        <.icon name="hero-check" class="w-4 h-4 text-white" />
                      <% end %>
                    </div>
                  <% else %>
                    <%!-- Text Option --%>
                    <div class="flex items-center gap-3">
                      <div class={[
                        "w-5 h-5 sm:w-6 sm:h-6 rounded-full border-2 flex items-center justify-center shrink-0",
                        if @selected_answer == option do
                          "border-primary bg-primary"
                        else
                          "border-base-300"
                        end
                      ]}>
                        <%= if @selected_answer == option do %>
                          <div class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full bg-white"></div>
                        <% end %>
                      </div>
                      <span class="text-base-content font-medium text-sm sm:text-base">
                        {display_option}
                      </span>
                    </div>
                  <% end %>
                </button>
              <% end %>
            </div>

            <%!-- Actions --%>
            <div class="flex flex-col sm:flex-row gap-3">
              <button
                type="button"
                phx-click="submit_answer"
                disabled={is_nil(@selected_answer)}
                class="w-full sm:w-auto px-4 sm:px-6 py-3 bg-primary text-primary-content rounded-xl font-medium hover:bg-primary/90 disabled:opacity-50 disabled:cursor-not-allowed transition-colors min-h-[48px] order-1"
              >
                {gettext("Submit Answer")}
              </button>

              <button
                type="button"
                phx-click="skip_question"
                class="w-full sm:w-auto sm:ml-auto px-4 py-3 bg-base-200 hover:bg-base-300 text-base-content rounded-xl transition-colors min-h-[48px] order-2 sm:order-3"
              >
                {gettext("Skip →")}
              </button>
            </div>
          <% end %>
        </div>
      <% else %>
        <%!-- Empty/Complete State --%>
        <div class="bg-base-100 rounded-2xl shadow-sm border border-base-200 p-6 sm:p-8 text-center">
          <.icon
            name="hero-check-circle"
            class="w-12 h-12 sm:w-16 sm:h-16 text-success mx-auto mb-3 sm:mb-4"
          />
          <h2 class="text-xl sm:text-2xl font-bold text-base-content mb-2">
            {gettext("Test Complete!")}
          </h2>
          <p class="text-secondary mb-4 sm:mb-6 text-sm sm:text-base">
            {gettext("You've completed all questions in today's daily review.")}
          </p>
          <.link
            navigate={~p"/daily-test/complete"}
            class="inline-flex items-center justify-center gap-2 px-4 sm:px-6 py-2.5 sm:py-3 bg-primary text-primary-content rounded-xl font-medium hover:bg-primary/90 transition-colors min-h-[44px]"
          >
            {gettext("View Results")}
          </.link>
        </div>
      <% end %>

      <%!-- Feedback Toast --%>
      <%= case @feedback do %>
        <% :correct -> %>
          <div
            class="fixed bottom-4 sm:bottom-6 left-1/2 -translate-x-1/2 bg-success text-success-content px-4 sm:px-6 py-2.5 sm:py-3 rounded-xl shadow-lg flex items-center gap-2 sm:gap-3 animate-in slide-in-from-bottom-2 z-50 max-w-[calc(100vw-2rem)]"
            phx-click="clear_feedback"
            phx-hook="AutoDismiss"
            id="feedback-toast-correct"
          >
            <.icon name="hero-check-circle" class="w-5 h-5 shrink-0" />
            <span class="font-medium text-sm sm:text-base">{gettext("Correct! Well done.")}</span>
          </div>
        <% :incorrect -> %>
          <div
            class="fixed bottom-4 sm:bottom-6 left-1/2 -translate-x-1/2 bg-error text-error-content px-4 sm:px-6 py-2.5 sm:py-3 rounded-xl shadow-lg flex items-center gap-2 sm:gap-3 animate-in slide-in-from-bottom-2 z-50 max-w-[calc(100vw-2rem)]"
            phx-click="clear_feedback"
            phx-hook="AutoDismiss"
            id="feedback-toast-incorrect"
          >
            <.icon name="hero-x-circle" class="w-5 h-5 shrink-0" />
            <span class="font-medium text-sm sm:text-base">
              {gettext("Not quite. Keep going!")}
            </span>
          </div>
        <% _ -> %>
      <% end %>
    <% end %>
  </div>
</Layouts.app>
