<Layouts.app flash={@flash} current_scope={@current_scope} socket={@socket}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <%!-- Header --%>
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <div class="flex items-center gap-2 mb-2">
          <.link navigate={~p"/moderator"} class="btn btn-sm btn-ghost">
            <.icon name="hero-arrow-left" class="w-4 h-4" />
          </.link>
          <h1 class="text-3xl font-bold text-base-content">{gettext("Kanji Management")}</h1>
        </div>
        <p class="mt-1 text-secondary">
          {gettext("Manage kanji characters. Total: %{count}", count: @total_count)}
        </p>
      </div>
      <.link
        navigate={~p"/moderator/kanji/new"}
        class="btn btn-primary w-full sm:w-auto min-h-[44px] touch-target"
      >
        <.icon name="hero-plus" class="w-5 h-5 mr-2" /> {gettext("Add Kanji")}
      </.link>
    </div>

    <%!-- Filters --%>
    <div class="card bg-base-100 shadow-sm border border-base-300 mb-6">
      <div class="card-body p-4 sm:p-6">
        <div class="flex flex-col gap-4">
          <%!-- Level Filter --%>
          <div class="flex flex-col sm:flex-row sm:items-center gap-2">
            <span class="text-sm font-medium text-base-content/70 shrink-0">
              {gettext("Filter by level:")}
            </span>
            <div class="flex flex-wrap gap-1">
              <button
                phx-click="filter_level"
                phx-value-level=""
                class={[
                  "btn btn-sm min-h-[40px] touch-target",
                  if(is_nil(@level_filter) || @level_filter == "",
                    do: "btn-active btn-primary",
                    else: "btn-ghost"
                  )
                ]}
              >
                {gettext("All")}
              </button>
              <%= for level <- 5..1//-1 do %>
                <button
                  phx-click="filter_level"
                  phx-value-level={level}
                  class={[
                    "btn btn-sm min-h-[40px] touch-target",
                    if(@level_filter == to_string(level),
                      do: "btn-active btn-primary",
                      else: "btn-ghost"
                    )
                  ]}
                >
                  N{level}
                </button>
              <% end %>
            </div>
          </div>

          <%!-- Search --%>
          <.form
            for={%{}}
            phx-submit="search"
            class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2 w-full"
          >
            <div class="join w-full sm:flex-1">
              <input
                type="text"
                name="search[query]"
                value={@search}
                placeholder={gettext("Search kanji or meaning...")}
                class="join-item input input-bordered w-full text-base min-h-[48px]"
              />
            </div>
            <div class="flex gap-2">
              <button
                type="submit"
                class="btn btn-primary min-h-[48px] touch-target flex-1 sm:flex-none px-4"
              >
                <.icon name="hero-magnifying-glass" class="w-5 h-5 sm:mr-2" />
                <span class="hidden sm:inline">{gettext("Search")}</span>
              </button>
              <%= if @search || @level_filter do %>
                <button
                  type="button"
                  phx-click="clear_filters"
                  class="btn btn-ghost min-h-[48px] touch-target px-4"
                >
                  {gettext("Clear")}
                </button>
              <% end %>
            </div>
          </.form>
        </div>
      </div>
    </div>

    <%!-- Kanji Grid --%>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
      <%= for k <- @kanji do %>
        <div class="card bg-base-100 shadow-sm border border-base-300 hover:shadow-md transition-shadow">
          <div class="card-body p-4">
            <div class="flex justify-between items-start">
              <span class={["badge badge-sm", level_badge_color(k.jlpt_level)]}>
                N{k.jlpt_level}
              </span>
              <div class="flex gap-1">
                <.link
                  navigate={~p"/moderator/kanji/#{k.id}/edit"}
                  class="btn btn-ghost btn-sm min-h-[36px] min-w-[36px] touch-target"
                  title={gettext("Edit")}
                >
                  <.icon name="hero-pencil" class="w-4 h-4" />
                </.link>
                <button
                  phx-click="delete"
                  phx-value-id={k.id}
                  data-confirm={gettext("Are you sure you want to delete this kanji?")}
                  class="btn btn-ghost btn-sm text-error min-h-[36px] min-w-[36px] touch-target"
                  title={gettext("Delete")}
                >
                  <.icon name="hero-trash" class="w-4 h-4" />
                </button>
              </div>
            </div>

            <div class="text-center py-3">
              <div class="text-5xl font-serif text-base-content">{k.character}</div>
            </div>

            <div class="text-center">
              <div class="text-sm text-base-content/70 truncate">
                {Enum.join(k.meanings, ", ")}
              </div>
              <div class="text-xs text-base-content/50 mt-1">
                {k.stroke_count} {gettext("strokes")}
              </div>
            </div>

            <%= if k.translations != %{} do %>
              <div class="flex justify-center gap-1 mt-2">
                <%= if get_in(k.translations, ["bg", "meanings"]) do %>
                  <span class="badge badge-xs badge-primary">BG</span>
                <% end %>
                <%= if get_in(k.translations, ["ja", "meanings"]) do %>
                  <span class="badge badge-xs badge-secondary">JA</span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%= if @kanji == [] do %>
      <div class="p-12 text-center">
        <.icon name="hero-language" class="w-12 h-12 text-base-content/30 mx-auto mb-4" />
        <p class="text-base-content/50">{gettext("No kanji found matching your criteria.")}</p>
      </div>
    <% end %>

    <%!-- Pagination --%>
    <%= if @total_pages > 1 do %>
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3 mt-6">
        <div class="text-sm text-base-content/60">
          {gettext("Page %{page} of %{total}", page: @page, total: @total_pages)}
        </div>
        <div class="join">
          <.link
            navigate={
              if @page > 1,
                do: ~p"/moderator/kanji?#{%{page: @page - 1, level: @level_filter, search: @search}}",
                else: "#"
            }
            class={["join-item btn btn-sm min-w-[40px]", if(@page <= 1, do: "btn-disabled")]}
          >
            <.icon name="hero-chevron-left" class="w-4 h-4" />
          </.link>
          <%= for page_num <- 1..@total_pages do %>
            <%= if abs(page_num - @page) <= 2 or page_num == 1 or page_num == @total_pages do %>
              <.link
                navigate={
                  ~p"/moderator/kanji?#{%{page: page_num, level: @level_filter, search: @search}}"
                }
                class={[
                  "join-item btn btn-sm w-10 h-10 min-w-[40px] max-w-[40px] p-0",
                  if(page_num == @page, do: "btn-active btn-primary", else: "btn-ghost")
                ]}
              >
                {page_num}
              </.link>
            <% end %>
          <% end %>
          <.link
            navigate={
              if @page < @total_pages,
                do: ~p"/moderator/kanji?#{%{page: @page + 1, level: @level_filter, search: @search}}",
                else: "#"
            }
            class={[
              "join-item btn btn-sm min-w-[40px]",
              if(@page >= @total_pages, do: "btn-disabled")
            ]}
          >
            <.icon name="hero-chevron-right" class="w-4 h-4" />
          </.link>
        </div>
      </div>
    <% end %>
  </div>
</Layouts.app>
