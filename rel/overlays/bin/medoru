#!/bin/bash
#
# Medoru CLI - Release version
# This file gets copied to the release by mix release
#

set -e

# Get the release root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RELEASE_ROOT="$(dirname "$SCRIPT_DIR")"
RELEASE_BIN="$RELEASE_ROOT/bin/medoru"

# Ensure release binary exists
if [ ! -f "$RELEASE_BIN" ]; then
  echo "Error: Release binary not found at $RELEASE_BIN"
  exit 1
fi

# Show help
show_help() {
  echo "Medoru CLI"
  echo ""
  echo "Usage: $0 <command> [args]"
  echo ""
  echo "Custom commands:"
  echo "  make_admin <email>  Make a user an admin"
  echo "  version             Show application version"
  echo "  migrate             Run database migrations"
  echo "  seed                Seed the database"
  echo ""
  echo "Release commands:"
  echo "  start               Start the application (foreground)"
  echo "  daemon              Start as daemon (background)"
  echo "  stop                Stop the application"
  echo "  restart             Restart the application"
  echo "  remote              Connect to running app (remote console)"
  echo "  pid                 Show running PID"
  echo "  eval <code>         Evaluate Elixir code"
  echo "  rpc <code>          Execute RPC"
  echo ""
  echo "Examples:"
  echo "  $0 make_admin user@example.com"
  echo "  $0 migrate"
  echo "  $0 daemon"
}

# Handle custom commands
case "$1" in
  make_admin)
    if [ -z "$2" ]; then
      echo "Usage: $0 make_admin <email>"
      exit 1
    fi
    $RELEASE_BIN eval "Medoru.Release.make_admin(\"$2\")"
    ;;
  
  version)
    $RELEASE_BIN eval "Medoru.Release.version()"
    ;;
  
  migrate)
    $RELEASE_BIN eval "Medoru.Release.migrate()"
    ;;
  
  seed)
    $RELEASE_BIN eval "Medoru.Release.seed()"
    ;;
  
  help|--help|-h)
    show_help
    ;;
  
  *)
    # Pass through to release binary for standard commands
    $RELEASE_BIN "$@"
    ;;
esac
